{
  "name": "scheduler-ui",
  "version": "1.0.0",
  "description": "UI for users to schedule reports to their email regularly",
  "scripts": {
    "build": "fec build && npm run postbuild",
    "postbuild": "cp public/index.html dist/index.html",
    "start": "fec dev",
    "start:proxy": "PROXY=true fec dev",
    "verify": "npm-run-all build lint test",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "playwright:install": "playwright install --with-deps",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "postinstall": "ts-patch install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RedHatInsights/scheduler-ui"
  },
  "keywords": [
    "red-hat",
    "insights",
    "scheduler",
    "reports"
  ],
  "author": "Red Hat",
  "license": "Apache-2.0",
  "dependencies": {
    "@patternfly/patternfly": "^6.4.0",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-data-view": "^6.4.0",
    "@patternfly/react-data-view-root": "github:patternfly/react-data-view#main",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.3",
    "@redhat-cloud-services/frontend-components": "^7.4.2",
    "@redhat-cloud-services/frontend-components-utilities": "^7.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@playwright/test": "^1.59.1",
    "@redhat-cloud-services/frontend-components-config": "^6.9.1",
    "@redhat-cloud-services/tsc-transform-imports": "^1.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-jest": "^30.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all2": "^5.0.2",
    "ts-jest": "^29.4.9",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.3"
  },
  "insights": {
    "appname": "scheduler-ui"
  }
}
